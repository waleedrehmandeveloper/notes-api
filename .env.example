# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE (.env.example)
#
# INSTRUCTIONS:
# Copy this file to a new file named `.env` in the root directory:
# cp .env.example .env
#
# Modify the values below to match your local or production environment.
# DO NOT commit the `.env` file containing actual secrets to version control!
# ==============================================================================

# 1. Server Configuration
# The port number on which the Express.js server will listen.
# Used in: app.js
PORT=5000

# 2. Database Configuration
# The Connection URI for MongoDB.
# - Local database default: mongodb://127.0.0.1:27017/notesdb
# - Remote/Atlas database: mongodb+srv://<username>:<password>@cluster.mongodb.net/notesdb
# Used in: config/db.js (via mongoose.connect)
MONGODB_URI=mongodb://127.0.0.1:27017/notesdb

# 3. Application Environment Mode
# Defines the current execution mode (development, production, test).
# - development: Enables verbose console logging and stack traces.
# - production: Disables details/traces in error messages for security.
# Used in: app.js and middleware/errorHandler.js
NODE_ENV=development
